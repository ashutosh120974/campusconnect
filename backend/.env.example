# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database (MongoDB Atlas in production)
MONGODB_URI=mongodb://127.0.0.1:27017/campusconnect

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_TTL_MINUTES=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- Phase 2+ integrations (not required for the foundation) ---
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# AWS S3
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Email (SES/SendGrid)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
